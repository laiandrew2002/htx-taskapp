DATABASE_URL=postgresql://taskapp:taskapp_secret@localhost:5432/taskapp
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost

# LLM provider: gemini | openai
LLM_PROVIDER=openai

# Gemini (when LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI-compatible / OpenRouter (when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-oss-20b:free
OPENAI_HTTP_REFERER=http://localhost
OPENAI_APP_NAME=htx-taskapp
